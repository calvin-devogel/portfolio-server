#!/bin/sh
RED='\033[31m'
YELLOW='\033[33m'
GREEN='\033[32m'
RESET = '\033[0m'

fail() {
    printf "${RED}✗${RESET} %s failed. Push aborted." >&2
    exit 1
}

echo "→ Formatting..."
cargo fmt --check || fail "Formatting"

echo "→ Running Clippy..."
cargo clippy -- -D warnings || fail "Clippy"

echo "→ Running tests..."
cargo test || fail "Tests"

echo "→ Auditing dependencies..."
cargo audit || echo "${YELLOW}⚠${RESET} Audit found vulnerabilities (non-blocking)." >&2

echo "→ Looking for unused dependencies..."
cargo machete || fail "Machete"

echo "→ Preparing queries"
sqlx prepare -- --all-targets || fail "Query Prep"

echo "${GREEN}✓${RESET} Pre-push checks passed."