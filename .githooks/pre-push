#!/bin/sh
RED='\033[31m'
YELLOW='\033[33m'
GREEN='\033[32m'
RESET='\033[0m'

fail() {
    printf "${RED}✗${RESET} %s failed. Push aborted." "$1" >&2
    exit 1
}

echo "\n→ Formatting...\n"
cargo fmt --check || fail "Formatting"

echo "\n→ Running Clippy...\n"
cargo clippy -- -D warnings || fail "Clippy"

echo "\n→ Running tests...\n"
cargo test || fail "Tests"

echo "\n→ Auditing dependencies...\n"
cargo audit || echo "\n${YELLOW}⚠${RESET} Audit found vulnerabilities (non-blocking).\n" >&2

echo "\n→ Looking for unused dependencies...\n"
cargo machete || fail "Machete"

echo "\n→ Preparing queries\n"
cargo sqlx prepare -- --all-targets || fail "Query Prep"

echo "\n${GREEN}✓${RESET} Pre-push checks passed.\n"